// ========================================
// Firestore Rules
// ========================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function owns(data) {
      return signedIn() && data.ownerId == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == 'user';
      allow update: if signedIn() && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'subscriptionStatus', 'planId', 'currentPeriodEnd', 'renewalDay']);
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if resource.data.status == 'active' || owns(resource.data);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if owns(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId;
    }

    match /videos/{videoId} {
      allow read: if resource.data.status == 'published' || owns(resource.data);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if owns(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId;
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /templates/{templateId} {
      allow read: if resource.data.isGlobal == true || owns(resource.data);
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.isGlobal == false;
      allow update, delete: if owns(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.isGlobal == false;
    }

    match /music/{musicId} {
      allow read: if resource.data.isGlobal == true || owns(resource.data);
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.isGlobal == false;
      allow update, delete: if owns(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.isGlobal == false;
    }
  }
}

// Storage uploads moved to the Render backend + Supabase Storage.
// Keep Firebase Storage writes disabled unless you intentionally add a backend-admin path.
