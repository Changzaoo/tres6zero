{
  "name": "tres6zero",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:server & npm run dev:web",
    "dev:web": "npm --workspace=apps/web run dev",
    "dev:server": "npm --workspace=apps/server run dev",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm --workspace=apps/web run lint && npm --workspace=apps/server run lint",
    "typecheck": "npm --workspace=apps/web run typecheck && npm --workspace=apps/server run typecheck",
    "start": "npm --workspace=apps/server run start"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.3"
  }
}
